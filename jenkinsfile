pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Code checkout...'
                git branch: 'main', url: 'https://github.com/Hareeshreddyhari/mindcircuit17d.git'
            }
        }

        stage('Build') {
            steps {
                echo 'Building the code...'
                sh 'mvn clean install'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying to Tomcat...'
            deploy adapters: [tomcat9(alternativeDeploymentContext: '', credentialsId: 'tomcat', path: '', url: 'http://23.20.227.251:8080')], contextPath: 'harry', war: '**/*.war'
            }
        }
    }

    post {
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}
